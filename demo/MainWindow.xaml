<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng nhập - Hermes" Height="500" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Border Background="White" CornerRadius="10" Margin="40" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="🔒 Hermes" FontSize="24" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,30" Foreground="#1F2937"/>

                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtEmail" Height="35" Padding="5" Margin="0,0,0,15" 
                         VerticalContentAlignment="Center" FontSize="14"/>

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtPassword" Height="35" Padding="5" Margin="0,0,0,25" 
                             VerticalContentAlignment="Center" FontSize="14"/>

                <TextBlock Text="Quên mật khẩu?" Foreground="#3B82F6" FontWeight="SemiBold" FontSize="12"
                    Cursor="Hand" HorizontalAlignment="Right" Margin="0,-15,0,20" 
                    MouseLeftButtonDown="TextBlock_ForgotPassword_Click"/>

                <Button x:Name="btnLogin" Content="ĐĂNG NHẬP" IsDefault="True" Height="40" Background="#3B82F6" 
                    Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnLogin_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Chưa có tài khoản? " Foreground="#6B7280"/>
                    <TextBlock Text="Đăng ký ngay" Foreground="#3B82F6" FontWeight="SemiBold" 
                        Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="TextBlock_Register_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>