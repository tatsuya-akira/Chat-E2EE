<Window x:Class="demo.ForgotPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Quên mật khẩu - Hermes" Height="450" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Border Background="White" CornerRadius="10" Margin="40" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Khôi phục mật khẩu" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,10" Foreground="#1F2937"/>

                <TextBlock Text="Nhập email của bạn để nhận mã khôi phục." TextWrapping="Wrap" 
                           TextAlignment="Center" Foreground="#6B7280" Margin="0,0,0,25"/>

                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtForgotEmail" Height="35" Padding="5" Margin="0,0,0,25" 
                         VerticalContentAlignment="Center" FontSize="14" BorderBrush="#D1D5DB"/>

                <Button x:Name="btnSendCode" Content="GỬI MÃ" IsDefault="True" Height="40" Background="#F59E0B" 
                    Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnSendCode_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Nhớ mật khẩu rồi? " Foreground="#6B7280"/>
                    <TextBlock Text="Đăng nhập" Foreground="#3B82F6" FontWeight="SemiBold" 
                               Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="TextBlock_BackToLogin_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>