<Window x:Class="Hermes.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Đăng ký - Hermes" Height="650" Width="400"
        WindowStartupLocation="CenterScreen"
        Background="#F3F4F6">

    <Grid>
        <Border Background="White" CornerRadius="10" Margin="40" Padding="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Tạo tài khoản Hermes" FontSize="22" FontWeight="Bold" 
                           HorizontalAlignment="Center" Margin="0,0,0,25" Foreground="#1F2937"/>

                <TextBlock Text="Tên hiển thị (Username)" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtUsername" Height="35" Padding="5" Margin="0,0,0,15" 
                         VerticalContentAlignment="Center" FontSize="14" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Email" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <TextBox x:Name="txtRegEmail" Height="35" Padding="5" Margin="0,0,0,15" 
                         VerticalContentAlignment="Center" FontSize="14" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Mật khẩu" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtRegPassword" Height="35" Padding="5" Margin="0,0,0,15" 
                             VerticalContentAlignment="Center" FontSize="14" BorderBrush="#D1D5DB"/>

                <TextBlock Text="Xác nhận mật khẩu" FontWeight="SemiBold" Foreground="#4B5563" Margin="0,0,0,5"/>
                <PasswordBox x:Name="txtConfirmPassword" Height="35" Padding="5" Margin="0,0,0,25" 
                             VerticalContentAlignment="Center" FontSize="14" BorderBrush="#D1D5DB"/>

                <Button x:Name="btnRegister" Content="ĐĂNG KÝ" IsDefault="True" Height="40" Background="#10B981" 
                    Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnRegister_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <TextBlock Text="Đã có tài khoản? " Foreground="#6B7280"/>
                    <TextBlock Text="Đăng nhập" Foreground="#3B82F6" FontWeight="SemiBold" 
                               Cursor="Hand" TextDecorations="Underline" MouseLeftButtonDown="TextBlock_Login_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>