<Window x:Class="Hermes.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cài đặt" Height="400" Width="350"
        WindowStartupLocation="CenterOwner" Background="#F9FAFB" ResizeMode="NoResize">
    
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Cài đặt tài khoản" FontSize="20" FontWeight="Bold" Foreground="#1F2937" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1">
            <Ellipse Width="80" Height="80" Fill="#9CA3AF" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <TextBlock Text="Thông tin cá nhân" FontWeight="Bold" Foreground="#4B5563" Margin="0,10,0,5"/>
            <Border Background="White" BorderBrush="#D1D5DB" BorderThickness="1" CornerRadius="5" Padding="10">
                <StackPanel>
                    <TextBlock x:Name="txtUserEmail" Text="Email: ..." Foreground="#6B7280" Margin="0,0,0,5"/>
                    <TextBlock x:Name="txtUserId" Text="ID: ..." Foreground="#6B7280"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <Button x:Name="btnLogout" Grid.Row="2" Content="Đăng xuất" Height="40" Background="#EF4444" 
                Foreground="White" FontWeight="Bold" FontSize="14" Cursor="Hand" Click="btnLogout_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>
    </Grid>
</Window>